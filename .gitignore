# =============================================================================
# LSD project .gitignore
# Mirrors everything removed by `make clean` in sim/, plus Visualizer cache.
# =============================================================================

# -----------------------------------------------------------------------------
# Questasim build artifacts (match `make clean` in sim/Makefile)
# -----------------------------------------------------------------------------
sim/work/
sim/transcript
sim/transcript.*
sim/vsim.wlf
sim/vsim.wlf.*
sim/tb.vcd
sim/design.bin
sim/design.bin.*
sim/*.db
sim/*.db/
sim/*.log
sim/modelsim.ini
sim/tb_top_opt
sim/tb_top_opt/
sim/covhtmlreport/
sim/qrun.out
sim/qrun.out/
sim/*.xml

# Same patterns but caught anywhere (defensive — some tools emit to cwd)
work/
transcript
*.wlf
*.wlf.*
*.db
*.db/
*.log
modelsim.ini
design.bin
design.bin.*
tb_top_opt
tb_top_opt/
covhtmlreport/
qrun.out
qrun.out/

# -----------------------------------------------------------------------------
# Visualizer runtime cache / config / profile
# -----------------------------------------------------------------------------
.visualizer/
**/.visualizer/

# -----------------------------------------------------------------------------
# Editor / IDE / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Python helpers (tools/gen_bloat.py etc.)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Auto-generated bloat farms — regenerated by `make gen`, do not commit.
# Every family now lives in its own subdirectory of rtl/gen/ (see the
# sim/Makefile `gen` target for the full list of families).
#
# The top-level rtl/gen/*.sv and rtl/gen/*.f rules also catch any stragglers
# from the previous flat layout, so an unclean working tree mid-migration
# does not accidentally stage 16k generated files.
# -----------------------------------------------------------------------------
rtl/gen/*/
rtl/gen/lsd_*.sv
rtl/gen/*.f
