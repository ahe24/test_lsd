# =============================================================================
# LSD project .gitignore
# Mirrors everything removed by `make clean` in sim/, plus Visualizer cache.
# =============================================================================

# -----------------------------------------------------------------------------
# Questasim build artifacts (match `make clean` in sim/Makefile)
# -----------------------------------------------------------------------------
sim/work/
sim/transcript
sim/transcript.*
sim/vsim.wlf
sim/vsim.wlf.*
sim/tb.vcd
sim/design.bin
sim/design.bin.*
sim/*.db
sim/*.db/
sim/*.log
sim/modelsim.ini
sim/tb_top_opt
sim/tb_top_opt/
sim/covhtmlreport/
sim/qrun.out
sim/qrun.out/
sim/*.xml

# Same patterns but caught anywhere (defensive — some tools emit to cwd)
work/
transcript
*.wlf
*.wlf.*
*.db
*.db/
*.log
modelsim.ini
design.bin
design.bin.*
tb_top_opt
tb_top_opt/
covhtmlreport/
qrun.out
qrun.out/

# -----------------------------------------------------------------------------
# Visualizer runtime cache / config / profile
# -----------------------------------------------------------------------------
.visualizer/
**/.visualizer/

# -----------------------------------------------------------------------------
# Editor / IDE / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Python helpers (tools/gen_bloat.py etc.)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Auto-generated bloat farms — regenerated by `make gen`, do not commit.
# Three families emit into rtl/gen/; comment out the block if you want any
# of them in VCS.
#   family 1: gen_bloat.py   -> lsd_bloat_*
#   family 2: gen_bloat2.py  -> lsd_bloat2_*
#   family 3: gen_churn.py   -> lsd_churn_*
# -----------------------------------------------------------------------------
rtl/gen/lsd_bloat_u*.sv
rtl/gen/lsd_bloat_farm.sv
rtl/gen/gen_filelist.f

rtl/gen/lsd_bloat2_u*.sv
rtl/gen/lsd_bloat2_farm.sv
rtl/gen/gen2_filelist.f

rtl/gen/lsd_churn_u*.sv
rtl/gen/lsd_churn_farm.sv
rtl/gen/gen_churn_filelist.f
